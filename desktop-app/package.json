{
  "name": "saas-optimizer-desktop",
  "version": "1.0.0",
  "description": "SaaS Optimizer Desktop App with device integrations",
  "main": "src/main.js",
  "scripts": {
    "start": "electron .",
    "dev": "electron . --dev",
    "build": "electron-builder",
    "build:mac": "electron-builder --mac",
    "build:win": "electron-builder --win",
    "build:linux": "electron-builder --linux"
  },
  "keywords": [
    "saas",
    "subscription",
    "optimizer",
    "desktop"
  ],
  "author": "SaaS Optimizer",
  "license": "MIT",
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1"
  },
  "dependencies": {
    "axios": "^1.6.2",
    "electron-store": "^8.1.0",
    "node-notifier": "^10.0.1",
    "node-machine-id": "^1.1.12",
    "mailparser": "^3.6.5",
    "ical": "^0.8.0",
    "tesseract.js": "^5.0.4",
    "sqlite3": "^5.1.6"
  },
  "build": {
    "appId": "com.saasoptimizer.desktop",
    "productName": "SaaS Optimizer",
    "directories": {
      "output": "dist"
    },
    "files": [
      "src/**/*",
      "assets/**/*",
      "package.json"
    ],
    "mac": {
      "category": "public.app-category.finance",
      "target": ["dmg", "zip"],
      "icon": "assets/icon.icns"
    },
    "win": {
      "target": ["nsis", "portable"],
      "icon": "assets/icon.ico"
    },
    "linux": {
      "target": ["AppImage", "deb"],
      "category": "Finance",
      "icon": "assets/icon.png"
    }
  }
}
